# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AnonChat Server - Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Environment
NODE_ENV=production

# Server
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/anonchat
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/anonchat

# Admin Credentials (CHANGE THESE!)
# Generate random strings: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_USERNAME=admin_change_this_to_random_string
ADMIN_PASSWORD=change_this_to_very_long_random_password_at_least_64_characters

# Session Secret (CHANGE THIS!)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_random_128_character_string

# CORS
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Rate Limiting
MAX_CONNECTIONS_PER_IP=3
RATE_LIMIT_WINDOW=10000
RATE_LIMIT_MAX=10

# Optional: MongoDB credentials (if using local MongoDB)
# MONGO_USERNAME=admin
# MONGO_PASSWORD=your_secure_password
